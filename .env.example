# ScreenScraper Developer Credentials
# Estas credenciales son proporcionadas por ScreenScraper cuando aprueba tu solicitud de desarrollador
# Ver: https://www.screenscraper.fr/membreinfos.php
#
# IMPORTANTE: Copia este archivo a .env y rellena tus credenciales reales
# El archivo .env nunca debe subirse al repositorio (esta en .gitignore)

# ID de desarrollador (proporcionado por ScreenScraper)
SS_DEV_ID=your_dev_id_here

# Contrasena de desarrollador (proporcionado por ScreenScraper)
SS_DEV_PASSWORD=your_dev_password_here

# Nombre de tu aplicacion (como la registraste en ScreenScraper)
SS_SOFT_NAME=LutrisGameStation
